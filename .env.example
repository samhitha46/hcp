# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# --- MySQL ---
DB_HOST=your-db-host.rds.amazonaws.com
DB_PORT=3306
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=your_password

# Connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# --- Logging ---
LOG_LEVEL=INFO
# "text" for human-readable, "json" for structured/machine-readable
LOG_FORMAT=text

GA4_PROPERTY_ID=your_property_id
GA4_CREDENTIALS_FILE=/path/to/your/credentials.json

# --- ZeroBounce ---
# Get your API key at https://www.zerobounce.net/members/apikey
ZEROBOUNCE_API_KEY=your_zerobounce_api_key
